# ============================================================
# Python — caches et artefacts compilés
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
*.egg-info/

# ============================================================
# Environnements virtuels
# ============================================================
venv/
.venv/
env/
.env/
poetry.lock

# ============================================================
# Distribution / packaging
# ============================================================
dist/
build/

# ============================================================
# Fichiers de sortie générés par le programme
# ============================================================
maze.txt
*.out

# ============================================================
# IDE et éditeurs
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Logs — conserver le dossier (via .gitkeep) mais ignorer les fichiers
# ============================================================
logs/*.txt
logs/*.log

# ============================================================
# Sujet du projet (non destiné au dépôt Git)
# ============================================================
docs/
*.bak
